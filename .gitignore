*~

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# make build-tests artifacts
tests/**/eden.*.test*
!tests/**/eden.*.tests.txt

# helper binaries built by `make -C tests/<dir> helper` (only the
# top-level binary copies — the cmd/<name>/ source dirs are kept).
tests/network/nim-bootstrap-pb-gen
tests/network/nim-bootstrap-pb-gen-*
tests/network/dist/bin/nim-bootstrap-pb-gen
tests/network/dist/bin/nim-bootstrap-pb-gen-*

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

dist
Config.in
/eden
build-tools

# workflow flavours
tests/workflow/workflow.default.txt
tests/workflow/workflow.small.txt
tests/workflow/workflow.large.txt

eve-config-dir/*

export
